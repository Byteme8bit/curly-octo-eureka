# Optional — only needed for private endpoints later.
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# USD pairs for momentum scoring (cross pairs auto-discovered from Kraken)
SYMBOLS=BTC/USD,ETH/USD,SOL/USD,ADA/USD,XRP/USD,DOT/USD,LINK/USD,AVAX/USD,ATOM/USD,LTC/USD,DOGE/USD,UNI/USD,AAVE/USD,ARB/USD,OP/USD,POL/USD

CORE_ASSETS=ETH,ADA,BTC

INITIAL_BALANCES={"ETH": 1.0, "ADA": 83.0, "USD": 0.0}
RESET_PAPER_STATE=0
# Human-readable portfolio snapshot (updated each tick; used for startup display)
PAPER_PORTFOLIO_FILE=paper_portfolio.json

POLL_INTERVAL=15
FEE_RATE=0.0026

CANDLE_TIMEFRAME=5m
CANDLE_LIMIT=60
EMA_FAST=9
EMA_SLOW=21
MOMENTUM_SELL=-0.002

TRADE_SIZE_PCT=0.10
EXPANSION_SIZE_PCT=0.15
MIN_USD_TRADE=10.0

# Soft preference for spreading into new/underweight coins (no hard caps)
DIVERSIFY_BONUS=0.0015
DUST_USD=25.0

MIN_TRADE_EDGE=0.006
FEE_SAFETY_MULTIPLIER=2.0
LEADER_STABLE_SECONDS=600
# After this many hours with no trades, loosen edge/net thresholds toward fee break-even
IDLE_REEVAL_HOURS=2
IDLE_REEVAL_MAX_ATTEMPTS=3

# Portfolio allocation rules
MIN_ETH_RESERVE=0.5
MAX_ALT_ALLOCATION_PCT=0.40

# Strategy governance — stick with winners, explore when flat
STRATEGY_GROWTH_WINDOW_HOURS=4
STRATEGY_MIN_GROWTH_PCT=0.005
STRATEGY_STRONG_GROWTH_PCT=0.015
STRATEGY_SWITCH_EDGE_MARGIN=0.002
STRATEGY_EXPLORATION_RATIO=0.25

TRADE_COOLDOWN_SECONDS=180
MAX_TRADES_PER_HOUR=12

# Hibernation — timed pause if circuit breaker disabled; otherwise use CIRCUIT_BREAKER
DRAWDOWN_HIBERNATE_PCT=0.15
HIBERNATE_HOURS=12
CIRCUIT_BREAKER_ENABLED=1
SAFE_ASSETS=USD,ETH,BTC

# Multi-strategy plugins (hot-swappable)
STRATEGIES=cross_momentum,triangular_arbitrage,stat_arb
SLIPPAGE_BUFFER_PCT=0.0005
MIN_NET_PROFIT_PCT=0.0005
MOMENTUM_TIMEFRAMES=15m,1h
STAT_ARB_ZSCORE_THRESHOLD=2.5
STAT_ARB_LOOKBACK=48
STAT_ARB_PAIRS=ETH/BTC,SOL/ETH,LINK/ETH,AVAX/ETH

LOG_ROTATE_HOURS=4

# Independent verifier (scripts/verify_trades.py) — optional tuning
VERIFIER_PRICE_TOLERANCE_PCT=0.02
VERIFIER_SLIPPAGE_ASSUME_PCT=0.005
VERIFIER_FEE_TOLERANCE_REL=0.15
VERIFIER_LIQUIDITY_WARN_RATIO=0.01
VERIFIER_LOG_WINDOW_MINUTES=30
# VERIFIER_SKIP_KRAKEN=1

# Discord — status updates + remote commands
DISCORD_ENABLED=0
DISCORD_WEBHOOK=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
# Comma-separated Discord user IDs allowed to send commands (required for commands)
DISCORD_ALLOWED_USER_IDS=
DISCORD_HEARTBEAT_MINUTES=30
# Min minutes between repeat posts of the same error to Discord
DISCORD_ERROR_COOLDOWN_MINUTES=15
# Pin errors only after the same error repeats (> count in window)
DISCORD_ERROR_PIN_COUNT=3
DISCORD_ERROR_PIN_WINDOW_MINUTES=30
# Pin important messages (errors, major PnL moves, big trades) — bot needs Manage Messages
DISCORD_PIN_ENABLED=1
DISCORD_PIN_PNL_PCT=0.05
DISCORD_PIN_TRADE_USD=25
DISCORD_MAX_PINS_RETAIN=15

# Optional other alert channels (hibernation also posts to DISCORD_WEBHOOK when enabled)
ALERTS_ENABLED=0
ALERT_DISCORD_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
ALERT_TWILIO_SID=
ALERT_TWILIO_TOKEN=
ALERT_TWILIO_FROM=
ALERT_SMS_TO=

# Logs: logs/ (4-hour Pacific time window files)
# Receipts: receipts/ (one file per trade)

# ---------------------------------------------------------------------------
# Watchdog — runs inside `python main.py` (same process as trade bot).
# Uses DISCORD_WEBHOOK / bot token above for alerts — WATCHDOG_DISCORD_WEBHOOK
# is optional (only needed for standalone `python watchdog/main.py`).
# WATCHDOG_* thresholds are separate from trade-bot DISCORD_* on purpose:
# trade bot controls its own pins/posts; watchdog controls monitor alerts.
# ---------------------------------------------------------------------------
WATCHDOG_ENABLED=1
# WATCHDOG_DISCORD_WEBHOOK=   # optional — defaults to DISCORD_WEBHOOK
WATCHDOG_POLL_SECONDS=10
WATCHDOG_STALE_MINUTES=5
WATCHDOG_TRADE_USD=25
WATCHDOG_PNL_PCT=0.05
WATCHDOG_DRAWDOWN_WARN_PCT=0.10

# Kraken API timeout + retry — default ccxt timeout is 10s; lower this so
# retries can finish within the trade-bot poll interval (15s).
KRAKEN_REQUEST_TIMEOUT_MS=5000
KRAKEN_MAX_RETRIES=2
KRAKEN_RETRY_BACKOFF_SEC=0.75

# Discord chat log — local mirror of all bot in/out chat for audit
DISCORD_CHAT_LOG_ENABLED=1
DISCORD_CHAT_LOG_FILE=logs/discord_chat.log
WATCHDOG_ERROR_COOLDOWN_MINUTES=15
WATCHDOG_AUTO_PAUSE_SCORE=25
WATCHDOG_ERROR_BURST_COUNT=5
WATCHDOG_ERROR_BURST_MINUTES=10
WATCHDOG_HEARTBEAT_MINUTES=15

# === Auditor (analyst bot) ===
# Audits past trades, fetches crypto news headlines, proposes tier-2 knob
# changes. Proposals require `Auditor -confirm <id>` to apply, and apply via
# runtime_overrides.json (NOT .env) so they're fully reversible.
AUDITOR_ENABLED=1
AUDITOR_DAILY_HOUR_PACIFIC=8
AUDITOR_TRADE_COUNT_TRIGGER=20
AUDITOR_PNL_PCT_TRIGGER=0.05
AUDITOR_NEWS_ENABLED=1
# Comma-separated provider chain. Free options (no key required):
#   rss        — aggregates CoinDesk, Cointelegraph, Decrypt, The Block, Bitcoin Magazine
#   coingecko  — CoinGecko /news endpoint (free tier; subject to throttling)
# Opt-in (deprecated — paid/limited):
#   cryptopanic — requires AUDITOR_CRYPTOPANIC_KEY for usable rate limits
AUDITOR_NEWS_PROVIDER=rss,coingecko
# Override the default RSS feed list. Format: Name|URL,Name|URL,...
# Leave blank to use the built-in defaults (CoinDesk, Cointelegraph, Decrypt,
# The Block, Bitcoin Magazine).
AUDITOR_RSS_FEEDS=
# Only used when "cryptopanic" appears in AUDITOR_NEWS_PROVIDER. Optional.
AUDITOR_CRYPTOPANIC_KEY=
AUDITOR_NEWS_MAX_ITEMS=10
AUDITOR_PROPOSAL_TTL_MINUTES=60
AUDITOR_REPORTS_DIR=reports

# --- Sleep-window auto-apply (DEFAULT OFF — opt-in only) ---
# Allows the auditor to apply ONE high-confidence proposal during a quiet
# overnight window without waiting for `Auditor -confirm`. After applying it
# also self-restarts the Python process to load the new value. Read
# feature_logs/020_auditor-autoapply.md before turning this on.
AUDITOR_AUTOAPPLY_ENABLED=0
# Window in 24h Pacific clock. start <= hour < end. To cross midnight set
# start > end (e.g. start=23 end=7 -> 23:00..07:00 PT).
AUDITOR_AUTOAPPLY_WINDOW_START_HOUR=1
AUDITOR_AUTOAPPLY_WINDOW_END_HOUR=7
# Minimum proposal severity that qualifies for auto-apply: low / medium / high.
# The proposer only marks the strongest signals (e.g. forecast central tendency
# negative across all horizons) as "high".
AUDITOR_AUTOAPPLY_MIN_SEVERITY=high
# Hard cap on auto-applies per night. Default 1 — never tune the bot twice
# while you're asleep.
AUDITOR_AUTOAPPLY_MAX_PER_NIGHT=1
# When 1, the bot self-restarts via os.execv after auto-applying so the new
# value loads immediately. When 0 the override is written but won't take
# effect until you restart manually.
AUDITOR_AUTOAPPLY_RESTART_ENABLED=1

# When 1 (default), a successful `Auditor -confirm <id>` self-restarts the bot
# so `runtime_overrides.json` loads immediately. Set 0 to apply the override
# but leave restart to you (same as before this feature).
AUDITOR_CONFIRM_RESTART=1

# --- Auditor conversational chat (DEFAULT OFF) ---
# Lets you ask Auditor questions in Discord about TradeBot/WatchDog state.
# Strictly read-only — chat can never execute trades or restart the bot.
# Commands:
#   Auditor -ask <question>   : single-turn Q&A
#   Auditor -chat <message>   : multi-turn (memory per Discord user)
#   Auditor -clearchat        : wipe your chat history
#   Auditor -chatstatus       : backend/model/active sessions
AUDITOR_CHAT_ENABLED=0
# Backend selector. Today: "gemini" or "null" (test stub). Anthropic/OpenAI
# may be added later through the same interface.
AUDITOR_CHAT_BACKEND=gemini
# Gemini model — free-tier per-day caps differ a LOT between models:
#   gemini-2.5-flash-lite : 15 RPM / 1000 RPD / 250K TPM  ← default (best headroom)
#   gemini-2.5-flash      : 10 RPM /  250 RPD / 250K TPM
#   gemini-2.0-flash      : 15 RPM /  200 RPD /   1M TPM  ← burns through fast
#   gemini-2.5-pro        :  5 RPM /   25 RPD / 250K TPM  ← deeper, very tight
# See https://ai.dev/gemini-api/docs/rate-limits for current values.
AUDITOR_CHAT_MODEL=gemini-2.5-flash-lite
# Get a free API key at https://aistudio.google.com (NOT the same as the
# consumer Gemini Pro subscription at gemini.google.com).
GEMINI_API_KEY=
# How many user/assistant pairs to remember per Discord user before pruning.
# Each remembered turn is resent on every subsequent chat → smaller = cheaper.
AUDITOR_CHAT_MAX_TURNS=6
# Hard cap on a single Gemini reply (tokens, not chars).
AUDITOR_CHAT_MAX_TOKENS=1000
# 0.0 = deterministic, 1.0 = creative. Keep low for factual Q&A.
AUDITOR_CHAT_TEMPERATURE=0.3
# Max LLM<->tool round-trips per question. Each round-trip is ONE API call,
# so 2 means a single chat costs at most 2 requests against the daily cap.
# Higher = the LLM can chain more lookups, but eats your quota faster.
AUDITOR_CHAT_TOOL_ITERATIONS=2
# Max chars from any single tool result before truncation. Tool outputs are
# resent on every subsequent loop iteration in the same chat, so this is the
# single biggest token-usage knob. 2000 is enough for a portfolio + 20 trades.
AUDITOR_CHAT_TOOL_RESULT_MAX_CHARS=2000

# Local read-only dashboard — TradeBot / Watchdog / Auditor tabs (no cloud deploy)
# Start: .\.venv\Scripts\python.exe -m dashboard  then open http://127.0.0.1:8765/
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8765
DASHBOARD_REFRESH_SECONDS=15
# DASHBOARD_BOT_ROOT=   # defaults to repo root

# ---------------------------------------------------------------------------
# Whale watch — alert-only monitoring of large Kraken trades + volume spikes.
# No extra API keys; uses public Kraken market data the bot already reaches.
# Persists to .whale_watch_state.json for the dashboard. Does NOT auto-trade.
# ---------------------------------------------------------------------------
WHALE_WATCH_ENABLED=0
# Minimum USD notional for large-trade detection (default $1M — true whale size).
WHALE_WATCH_MIN_USD=1000000
# Volume-spike notional floor (defaults to WHALE_WATCH_MIN_USD when unset).
WHALE_WATCH_SPIKE_MIN_USD=1000000
WHALE_WATCH_ASSETS=ETH,BTC,SOL
WHALE_WATCH_POLL_SECONDS=60
WHALE_WATCH_VOLUME_SPIKE_RATIO=3.0
WHALE_WATCH_MAX_EVENTS=100
# Post routine whale detections to Discord (default OFF). Watch + follow still run;
# events persist to .whale_watch_state.json and logs/whale_watch.log.
WHALE_WATCH_DISCORD_ALERTS=0
# WHALE_WATCH_LOG_FILE=logs/whale_watch.log

# ---------------------------------------------------------------------------
# Whale follow — optional paper trades mirroring whale signals (v2).
# Requires WHALE_WATCH_ENABLED=1. Default OFF; still passes fee + risk rails.
# ---------------------------------------------------------------------------
WHALE_FOLLOW_ENABLED=0
WHALE_FOLLOW_SIZE_PCT=0.15
WHALE_FOLLOW_COOLDOWN_SEC=300
WHALE_FOLLOW_MAX_PER_HOUR=2
WHALE_FOLLOW_MIN_NET_PROFIT=0.0005

# ---------------------------------------------------------------------------
# Goal evolution — portfolio milestones unlock strategies gradually (paper).
# Default ON. State: .tradebot_goals_state.json
# Tier 0 (<$10k): cross_momentum only
# Tier 1 ($10k+): + stat_arb
# Tier 2 ($100k+): + triangular_arbitrage, higher exploration
# Tier 3 ($1M+): full multi-strategy + whale-follow sizing bump
# ---------------------------------------------------------------------------
GOAL_EVOLUTION_ENABLED=1
# GOAL_STATE_FILE=.tradebot_goals_state.json
GOAL_MILESTONES_USD=10000,100000,1000000
GOAL_TIER0_STRATEGIES=cross_momentum
GOAL_TIER1_STRATEGIES=cross_momentum,stat_arb
GOAL_TIER2_STRATEGIES=cross_momentum,stat_arb,triangular_arbitrage
GOAL_TIER3_STRATEGIES=cross_momentum,stat_arb,triangular_arbitrage
GOAL_TIER2_EXPLORATION_RATIO=0.35
GOAL_TIER3_EXPLORATION_RATIO=0.40
GOAL_TIER3_WHALE_FOLLOW_SIZE_MULT=1.25

# Crash hold — hard stop for new risk during market stress (complements watchdog).
# Defensive trims still allowed; does not override circuit breaker / hibernate.
CRASH_HOLD_ENABLED=1
CRASH_HOLD_DRAWDOWN_PCT=0.08
CRASH_HOLD_SESSION_DRAWDOWN_PCT=0.06
CRASH_HOLD_RECOVERY_DRAWDOWN_PCT=0.05
CRASH_HOLD_MOMENTUM_THRESHOLD=-0.015
CRASH_HOLD_MOMENTUM_ASSET_RATIO=0.60
CRASH_HOLD_WATCHDOG_DRAWDOWN_PCT=0.10
CRASH_HOLD_MIN_MINUTES=30
