+    def _equity_candle_symbols(self) -> list[str]:
+        """Subset of equity USD pairs for momentum OHLCV (rate-limit friendly)."""
+        equity = [s for s in self.usd_symbols if s in self._equity_symbols]
+        scan_max = self._equity_momentum_scan_max
+        if scan_max <= 0 or len(equity) <= scan_max:
+            return equity
+        pref_syms = [
+            s for s in equity if s.split("/", 1)[0] in self._equity_preference_tickers
+        ]
+        pref_set = set(pref_syms)
+        rest = [s for s in equity if s not in pref_set]
+        budget = max(0, scan_max - len(pref_syms))
+        batch: list[str] = []
+        if budget > 0 and rest:
+            start = self._equity_scan_offset % len(rest)
+            for i in range(min(budget, len(rest))):
+                batch.append(rest[(start + i) % len(rest)])
+            self._equity_scan_offset = (start + len(batch)) % len(rest)
+        return pref_syms + batch
+
+    def _candle_fetch_symbols(self) -> list[str]:
+        crypto = [s for s in self.usd_symbols if s not in self._equity_symbols]
+        return crypto + self._equity_candle_symbols()
 
