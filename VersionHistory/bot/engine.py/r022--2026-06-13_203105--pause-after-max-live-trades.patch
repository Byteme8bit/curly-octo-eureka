+    def _after_live_trade(self) -> None:
+        """Pause live trading when LIVE_MAX_TRADES limit is reached."""
+        if not self._live_mode:
+            return
+        record = getattr(self.broker, "record_completed_trade", None)
+        if not callable(record):
+            return
+        count = record()
+        limit = self.settings.live_max_trades
+        if limit <= 0 or count < limit:
+            return
+        self.runtime.set_trading_active(False)
+        if hasattr(self.broker, "halt") and not getattr(self.broker, "halted", False):
+            self.broker.halt(f"Live trade limit reached ({count}/{limit})")
+        msg = f"{limit} live trades complete — paused"
+        logger.info(msg)
+        if self.settings.discord_enabled:
+            self.discord.post_important(
+                f"**{msg}**\nUse `-start` in Discord to resume when ready.",
+                pin=True,
+                source="TradeBot",
+            )
