+            f"live_mirrored={'yes' if trade.get('live_mirrored') else 'no'}"
+        )
+        append_force_trade_log(
+            self.settings.force_trade_log_file,
+            outcome="EXECUTED",
+            detail=log_detail,
+        )
+
+        body = format_trade_executed_alert(trade, portfolio, baseline_pnl)
+        headline = "**Force trade executed**"
+        if used_dca_fallback:
+            headline += " (DCA fallback)"
