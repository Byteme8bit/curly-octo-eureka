+
+        hop_label = f"{hops}-hop " if hops > 1 else ""
+        fallback_note = " (DCA fallback)" if used_dca_fallback else ""
+        strat = intent.strategy_name or "unknown"
+        log_detail = (
+            f"{intent.from_asset}->{intent.to_asset} net={net_edge:+.4f} "
