+    def _build_multipart_body(
+        self,
+        *,
+        fields: dict[str, str] | None = None,
+        payload_json: dict | None = None,
+        files: list[tuple[str, str, bytes, str]] | None = None,
+    ) -> tuple[bytes, str]:
+        boundary = f"----EthTradingBot{uuid.uuid4().hex}"
+        chunks: list[bytes] = []
+        if payload_json is not None:
+            chunks.append(
+                f'--{boundary}\r\nContent-Disposition: form-data; name="payload_json"\r\n'
+                f"Content-Type: application/json\r\n\r\n".encode()
+                + json.dumps(payload_json).encode("utf-8")
+                + b"\r\n"
+            )
+        for name, value in (fields or {}).items():
+            chunks.append(
+                f'--{boundary}\r\nContent-Disposition: form-data; name="{name}"\r\n\r\n'.encode()
+                + value.encode("utf-8")
+                + b"\r\n"
+            )
+        for field_name, fname, data, mime in files or []:
+            chunks.append(
+                f'--{boundary}\r\nContent-Disposition: form-data; name="{field_name}"; '
+                f'filename="{fname}"\r\nContent-Type: {mime}\r\n\r\n'.encode()
+                + data
+                + b"\r\n"
+            )
+        chunks.append(f"--{boundary}--\r\n".encode())
+        return b"".join(chunks), boundary
+
+    def _request_multipart(
+        self,
+        method: str,
+        url: str,
+        *,
+        payload_json: dict | None = None,
+        files: list[tuple[str, str, bytes, str]] | None = None,
+    ):
+        body, boundary = self._build_multipart_body(payload_json=payload_json, files=files)
+        headers = {
+            "Authorization": f"Bot {self.config.bot_token}",
+            "User-Agent": DISCORD_USER_AGENT,
+            "Content-Type": f"multipart/form-data; boundary={boundary}",
+        }
+        req = urllib.request.Request(url, data=body, headers=headers, method=method)
+        try:
+            with urllib.request.urlopen(req, timeout=30) as resp:
+                raw = resp.read().decode("utf-8")
+                if not raw:
+                    return None
+                return json.loads(raw)
+        except urllib.error.HTTPError as exc:
+            raise RuntimeError(_read_http_error(exc)) from exc
+
+    def _request_multipart_webhook(
+        self,
+        url: str,
+        *,
+        payload_json: dict | None = None,
+        files: list[tuple[str, str, bytes, str]] | None = None,
+    ):
+        body, boundary = self._build_multipart_body(payload_json=payload_json, files=files)
+        sep = "&" if "?" in url else "?"
+        target = f"{url}{sep}wait=true"
+        req = urllib.request.Request(
+            target,
+            data=body,
+            headers={
+                "User-Agent": DISCORD_USER_AGENT,
+                "Content-Type": f"multipart/form-data; boundary={boundary}",
+            },
+            method="POST",
+        )
+        try:
+            with urllib.request.urlopen(req, timeout=30) as resp:
+                raw = resp.read().decode("utf-8")
+                if not raw:
+                    return None
+                return json.loads(raw)
+        except urllib.error.HTTPError as exc:
+            raise RuntimeError(_read_http_error(exc)) from exc
 
