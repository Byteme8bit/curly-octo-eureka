+def _regime_headline_bullets(headlines: list[NewsHeadline], *, max_items: int = 2) -> list[str]:
+    """Return 1–2 ETH/BTC-relevant headline bullets for the regime context note.
+
+    Priority: ETH or BTC tagged headlines first; falls back to the first
+    untagged headline if nothing asset-specific is available.
+    """
+    priority = {"ETH", "BTC"}
+    tagged = [h for h in headlines if priority & set(h.tickers)]
+    picks = (tagged or headlines)[:max_items]
+    lines: list[str] = []
+    for h in picks:
+        tag = _format_news_tag(h)
+        title = h.title if len(h.title) <= 100 else h.title[:97] + "…"
+        lines.append(f"  - {tag} {title}")
+    return lines
 
 
