+def _stable_args_key(args) -> str:
+    """JSON-stable hash of tool arguments for per-turn caching."""
+    if not args:
+        return ""
+    try:
+        return json.dumps(args, sort_keys=True, default=str)
+    except Exception:  # noqa: BLE001
+        return repr(args)
