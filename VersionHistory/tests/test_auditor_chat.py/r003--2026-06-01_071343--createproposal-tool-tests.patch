+    from bot.auditor.chat.backends import _gemini_response_to_reply
+
+    fc = SimpleNamespace(name="get_portfolio_snapshot", args={"foo": 1}, id="call_1")
+    fc_part = SimpleNamespace(text=None, function_call=fc)
