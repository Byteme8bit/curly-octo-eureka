+def test_whale_watch_min_usd_default_one_million(monkeypatch):
+    monkeypatch.delenv("WHALE_WATCH_MIN_USD", raising=False)
+    monkeypatch.delenv("WHALE_WATCH_SPIKE_MIN_USD", raising=False)
+    settings = load_settings()
+    assert settings.whale_watch_min_usd == pytest.approx(1_000_000)
+    assert settings.whale_watch_spike_min_usd == pytest.approx(1_000_000)
+
+
+def test_whale_watcher_spike_uses_separate_floor(tmp_path: Path):
+    path = tmp_path / ".whale_watch_state.json"
+    rows = []
+    for i in range(15):
+        vol = 10.0 if i < 14 else 50.0
+        rows.append(
+            {
+                "timestamp": pd.Timestamp("2026-06-01", tz="UTC") + pd.Timedelta(minutes=5 * i),
+                "open": 100.0,
+                "high": 101.0,
+                "low": 99.0,
+                "close": 100.0,
+                "volume": vol,
+            }
+        )
+    df = pd.DataFrame(rows)
+
+    watcher = WhaleWatcher(
+        enabled=True,
+        assets=("BTC",),
+        min_usd=WHALE_MIN_USD,
+        spike_min_usd=WHALE_MIN_USD,
+        poll_seconds=60,
+        volume_spike_ratio=3.0,
+        max_events=50,
+        state_file=path,
+        data=None,  # type: ignore[arg-type]
+        fetch_trades=lambda _s, _l: [],
+        fetch_candles=lambda _sym: df,
+    )
+    events = watcher.maybe_poll()
+    assert len(events) == 0
+
+    watcher_loose = WhaleWatcher(
+        enabled=True,
+        assets=("BTC",),
+        min_usd=WHALE_MIN_USD,
+        spike_min_usd=4000,
+        poll_seconds=60,
+        volume_spike_ratio=3.0,
+        max_events=50,
+        state_file=path,
+        data=None,  # type: ignore[arg-type]
+        fetch_trades=lambda _s, _l: [],
+        fetch_candles=lambda _sym: df,
+    )
+    events = watcher_loose.maybe_poll()
+    assert len(events) == 1
+    assert events[0].source == "volume_spike"
 
 
