+        sentiment="positive",
+    )
+    no_source = NewsHeadline(
+        title="Market thoughts",
+        url="x",
+        published_at="2026-05-27",
+        source="",
+        tickers=[],
+        sentiment="negative",
+    )
+    bare = NewsHeadline(
