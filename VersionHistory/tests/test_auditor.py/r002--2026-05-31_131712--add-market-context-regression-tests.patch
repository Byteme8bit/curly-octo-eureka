+def test_render_discord_summary_uses_source_when_sentiment_unknown() -> None:
+    """RSS feeds carry source but no sentiment — we should show the publication name
+    instead of the visually-noisy `[unknown]` tag."""
+    from bot.auditor.report import _format_news_tag
+
+    rss_headline = NewsHeadline(
+        title="CFTC asks to vacate Gemini settlement",
+        url="https://coindesk.example/article",
+        published_at="2026-05-27",
+        source="CoinDesk",
+        tickers=["BTC"],
+        sentiment="unknown",
+    )
+    tagged = NewsHeadline(
+        title="ETH at all-time high",
+        url="x",
+        published_at="2026-05-27",
+        source="Cointelegraph",
+        tickers=["ETH"],
+        sentiment="positive",
+    )
+    no_source = NewsHeadline(
+        title="Market thoughts",
+        url="x",
+        published_at="2026-05-27",
+        source="",
+        tickers=[],
+        sentiment="negative",
+    )
+    bare = NewsHeadline(
+        title="Bare wire",
+        url="x",
+        published_at="",
+        source="",
+        tickers=[],
+        sentiment="unknown",
+    )
+    assert _format_news_tag(rss_headline) == "[CoinDesk]"
+    assert _format_news_tag(tagged) == "[Cointelegraph, positive]"
+    assert _format_news_tag(no_source) == "[negative]"
+    assert _format_news_tag(bare) == "[news]"
+
+    # And end-to-end: the summary should NOT contain "[unknown]" for RSS items.
+    insights = analyze_trades([_trade(gain=1.0)], {"ETH": 1.0}, _settings_stub())
+    forecast = forecast_pnl(insights, [_trade(gain=1.0)])
+    summary = render_discord_summary(insights, forecast, [rss_headline], [])
+    assert "[unknown]" not in summary
+    assert "[CoinDesk]" in summary
 
 
