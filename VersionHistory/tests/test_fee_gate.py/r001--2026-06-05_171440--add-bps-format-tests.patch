+def test_reject_reason_shows_bps():
+    """Reject reason must use basis-points notation, not raw decimals."""
+    pf = _validator(taker=0.0040, min_net=0.0005)
+    res = pf.validate(_intent(0.0040), route_symbols=("ETH/USD",), hops=1)
+    assert not res.allowed
+    assert "bps" in res.reason
+    assert "0.0040" not in res.reason
+
+
+def test_ok_reason_shows_bps():
+    """OK reason must use basis-points notation."""
+    pf = _validator(taker=0.0010, min_net=0.0001)
+    res = pf.validate(_intent(0.010), route_symbols=("ETH/USD",), hops=1)
+    assert res.allowed
+    assert "bps" in res.reason
+    assert "0." not in res.reason
