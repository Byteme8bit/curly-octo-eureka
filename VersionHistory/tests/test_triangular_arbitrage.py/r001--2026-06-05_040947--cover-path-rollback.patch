--- a/tests/test_triangular_arbitrage.py
+++ b/tests/test_triangular_arbitrage.py
@@ -127,3 +127,44 @@
         assert broker.balance("AAVE") == pytest.approx(0.0, abs=1e-9)
         # The profitable synthetic loop leaves us with MORE ETH than we started.
         assert broker.balance("ETH") > 1.0
+
+
+def test_failed_route_rolls_back_partial_leg_mutations(tmp_path: Path):
+    """If a later leg fails the min-trade gate, earlier leg balances are undone."""
+    broker = PaperBroker(
+        initial_balances={"USD": 5.0},
+        fee_rate=0.01,
+        state_file=tmp_path / "state.json",
+        min_usd_trade=5.0,
+        reset=True,
+    )
+    route = TradeRoute(
+        legs=(
+            RouteLeg(
+                PairInfo(symbol="ETH/USD", base="ETH", quote="USD"),
+                Signal.BUY,
+                from_asset="USD",
+                to_asset="ETH",
+            ),
+            RouteLeg(
+                PairInfo(symbol="ADA/ETH", base="ADA", quote="ETH"),
+                Signal.BUY,
+                from_asset="ETH",
+                to_asset="ADA",
+            ),
+        )
+    )
+
+    trade = broker.execute_path(
+        route=route,
+        prices={"ETH/USD": 2000.0, "ADA/ETH": 0.0002},
+        usd_prices={"USD": 1.0, "ETH": 2000.0, "ADA": 0.4},
+        reason="rollback regression",
+        size_pct=1.0,
+    )
+
+    assert trade is None
+    assert broker.state.balances == {"USD": 5.0}
+    assert broker.state.cost_basis == {}
+    assert broker.state.trades == []
+    assert not (tmp_path / "state.json").exists()
