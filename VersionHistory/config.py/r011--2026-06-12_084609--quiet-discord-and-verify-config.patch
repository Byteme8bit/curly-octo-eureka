+def _env_int(name: str, default: str, *, quiet: bool = False, quiet_default: str | None = None) -> int:
+    raw = os.getenv(name)
+    if raw is not None and str(raw).strip() != "":
+        return int(raw)
+    if quiet and quiet_default is not None:
+        return int(quiet_default)
+    return int(default)
+
